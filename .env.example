# ── Backend Configuration ─────────────────────────────────────
PORT=5001
NODE_ENV=development

# PostgreSQL connection string
# Railway'de otomatik olarak DATABASE_URL env değişkeni set edilir
# Format: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://user:pass@localhost:5432/aerosentinel

# ── Frontend Configuration ────────────────────────────────────
# Vite build için gerekli
VITE_BASE_PATH=/

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
