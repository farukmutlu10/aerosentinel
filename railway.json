{
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "artifacts/api-server/src/**",
      "artifacts/aero-sentinel/src/**",
      "lib/**"
    ]
  },
  "deploy": {
    "numReplicas": 1,
    "healthcheckPath": "/api/healthz",
    "healthcheckTimeout": 10,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
